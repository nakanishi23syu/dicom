{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Dicom": "Data Source=dicom.db"
  },
  "Cors": {
    // 本番等では環境ごとに実際のフロントエンドのオリジンを指定する（既定は空＝全拒否）。
    "AllowedOrigins": []
  },
  "Storage": {
    // アップロードされたDICOMファイルの保存先（ContentRootPathからの相対パス）。
    "DicomRoot": "Storage/dicom"
  },
  "Jwt": {
    "Issuer": "DicomLearning.GraphQL",
    "Audience": "DicomLearning.Frontend",
    "ExpiryMinutes": 480,
    // 署名鍵は秘密情報のためここには置かない。本番は環境変数(Jwt__SigningKey)や
    // シークレットマネージャー経由で必ず上書きすること（未設定のまま起動すると認証が機能しない）。
    "SigningKey": ""
  }
}
