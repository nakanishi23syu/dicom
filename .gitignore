# 依存パッケージ（npm install で再生成できるため不要）
node_modules/

# ビルド成果物
dist/

# ローカル環境固有の設定
.env
.env.local
.env.*.local

# エディタ設定
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# .NET（backend/ 配下のC#プロジェクトのビルド成果物）
backend/**/bin/
backend/**/obj/

# SQLite（ローカルで再生成できるDBファイル。スキーマはMigrationsで管理）
backend/**/*.db
backend/**/*.db-shm
backend/**/*.db-wal

# アップロードされたDICOMファイルの保存先（アプリデータのため）
backend/**/Storage/

# アップロード動作確認用にルート直下へ置くDICOMサンプルファイル（テスト用のため）
/*.dcm

# OS が自動生成するファイル
.DS_Store
Thumbs.db

# Python キャッシュ（frontend/download_dicom.py 実行時に生成）
__pycache__/
*.pyc

# ログ
*.log
npm-debug.log*

# TypeScript のビルドキャッシュ
*.tsbuildinfo
