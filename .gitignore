# 依存パッケージ（npm install で再生成できるため不要）
node_modules/

# ビルド成果物
dist/

# ローカル環境固有の設定
.env
.env.local
.env.*.local

# エディタ設定
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
# graphql/ の学習用C#プロジェクトはslnをコミット対象にするため除外を打ち消す
!graphql/**/*.sln

# .NET（graphql/ 配下の学習用C#プロジェクトのビルド成果物）
graphql/**/bin/
graphql/**/obj/

# OS が自動生成するファイル
.DS_Store
Thumbs.db

# ログ
*.log
npm-debug.log*

# TypeScript のビルドキャッシュ
*.tsbuildinfo
